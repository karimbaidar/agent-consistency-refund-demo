# Provider choices: heuristic, openai-compatible, ollama
MODEL_PROVIDER=heuristic

# Used by openai-compatible providers such as OpenAI, Azure OpenAI-compatible gateways,
# LiteLLM, vLLM, Together, Groq-compatible proxies, or internal enterprise endpoints.
MODEL_BASE_URL=https://api.openai.com/v1
MODEL_API_KEY=replace-me
MODEL_NAME=gpt-4o-mini

# Used by Ollama.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# Demo behavior.
CONSISTENCY_ON_VIOLATION=raise
OUTPUT_DIR=runs
